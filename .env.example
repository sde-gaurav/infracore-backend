# ---- Application ----
NODE_ENV=development
PORT=5000
APP_NAME=InfraCore
APP_URL=http://localhost:5000
CLIENT_URL=http://localhost:3000

# ---- MongoDB ----
MONGO_URI=mongodb://localhost:27017/infracore_dev
MONGO_URI_TEST=mongodb://localhost:27017/infracore_test

# ---- Redis ----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# ---- JWT ----
JWT_ACCESS_SECRET=change_this_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_this_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=infracore
JWT_AUDIENCE=infracore-clients

# ---- Bcrypt ----
BCRYPT_SALT_ROUNDS=12

# ---- Cookie ----
COOKIE_SECRET=change_this_cookie_secret_min_32_chars
COOKIE_SECURE=false
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=strict

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

# ---- Email (SMTP) ----
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@infracore.dev
EMAIL_FROM_NAME=InfraCore

# ---- File Upload ----
UPLOAD_PATH=src/uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf

# ---- Logging ----
LOG_LEVEL=debug
LOG_DIR=src/logs
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d

# ---- OTP ----
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6

# ---- Cors ----
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- Bull Queue ----
QUEUE_CONCURRENCY=5
QUEUE_ATTEMPTS=3
QUEUE_BACKOFF_DELAY=5000
